# AI provider: ollama | openai
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Rate limits (per day)
LINKEDIN_DAILY_MAX=25
INSTAGRAM_DAILY_MAX=40
# Connexion automatique du scraper Instagram (uniquement si sessions/instagram.json est absent ou trop petit).
# Si vous avez déjà fait `outreach.py login instagram`, laissez ces lignes vides : la session fichier suffit.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
EMAIL_DAILY_MAX=5
EMAIL_WARMUP_START_DATE=2026-05-18
WHATSAPP_DAILY_MAX=20

# Mode « off » = lien toujours si format OK. « gratuit » = filtre phonenumbers (fixe, vert…), sans réseau.
# « webhook » = POST vers votre URL (voir doc utils/whatsapp_verify.py).
# Exemple gratuit : WHATSAPP_VERIFY_MODE=gratuit
WHATSAPP_VERIFY_MODE=off
WHATSAPP_VERIFY_WEBHOOK_URL=
WHATSAPP_VERIFY_WEBHOOK_TOKEN=
WHATSAPP_VERIFY_WEBHOOK_TIMEOUT=12
WHATSAPP_VERIFY_UNKNOWN_KEEP_LINK=true

# Human-like delays (seconds)
DELAY_MIN=10
DELAY_MAX=60
PAUSE_EVERY_MIN=5
PAUSE_EVERY_MAX=10
LONG_PAUSE_MIN=120
LONG_PAUSE_MAX=300

# Paths
SCRAPER_OUTPUT_CSV=leads/scraper_output.csv
# Si défini : collecte Instagram écrite ici (séparé du CSV LinkedIn). Le connecteur fusionne les deux sources.
SCRAPER_INSTAGRAM_OUTPUT_CSV=leads/scraper_instagram.csv
LEADS_CSV=data/outreach_leads.csv
LOG_DIR=logs
SESSION_DIR=sessions

# Orchestrator
SCRAPER_COMMAND=python scraper.py run --mode hashtag --query test --app instagram --limit 10
ORCHESTRATOR_INTERVAL_HOURS=6
ORCHESTRATOR_HEADLESS=true
ORCHESTRATOR_INTERACTIVE=false
SCRAPER_HEADLESS=false
SCRAPER_FAST_MODE=false
SCRAPER_STABLE_LINKEDIN_MODE=true
SCRAPER_SESSION_MAX_AGE_DAYS=10
SCRAPER_INTER_PROFILE_PAUSE_SECONDS=3.5
SCRAPER_LINKEDIN_STABLE_MAX_PROFILES_PER_SEARCH=25
SCRAPER_LINKEDIN_STABLE_MAX_SEARCH_TERMS=4
SCRAPER_LINKEDIN_LONG_PAUSE_EVERY_MIN=6
SCRAPER_LINKEDIN_LONG_PAUSE_EVERY_MAX=10
SCRAPER_LINKEDIN_LONG_PAUSE_SECONDS_MIN=45
SCRAPER_LINKEDIN_LONG_PAUSE_SECONDS_MAX=120
SCRAPER_SKIP_PROFILE_REVISIT=true
SCRAPER_LINKEDIN_SKIP_COMPANY_ABOUT_WHEN_CONTACTED=true
# Timeout dashboard scraper (secondes). 14400 = 4 h. Augmentez si beaucoup de mots-clés LinkedIn.
SCRAPER_DASHBOARD_SUBPROCESS_TIMEOUT_SECONDS=14400
# 0 = illimité. Sinon tronque la liste (ex. 8) pour éviter des runs de plusieurs heures.
SCRAPER_LINKEDIN_MAX_SEARCH_TERMS=0
SCRAPER_LINKEDIN_ENRICH_PROFILES=true
# LinkedIn : n'écrire dans le CSV que les lignes avec e-mail ou WhatsApp (false = tout garder)
SCRAPER_LINKEDIN_REQUIRE_EMAIL_OR_WHATSAPP=true
SCRAPER_LINKEDIN_PRIORITIZE_EMAIL=true
SCRAPER_LINKEDIN_KEEP_SEARCHING_UNTIL_CONTACT=true
SCRAPER_LINKEDIN_QUICK_CONTACT_PROBE=true
SCRAPER_LINKEDIN_DEEP_ENRICH_ON_MATCH=true
SCRAPER_LINKEDIN_MAX_SEARCH_SCROLL_ROUNDS=5
SCRAPER_LINKEDIN_MAX_PROFILES_TO_TRY=25
SCRAPER_LINKEDIN_DEEP_ENRICH_ON_MATCH=false
SCRAPER_GUESS_EMAIL_RELAXED_MX_IN_FAST_MODE=true
# Exclure profils dont pays/bio contient ces mots (ex. Tunisie) — vide = pas de filtre géo
SCRAPER_EXCLUDE_LOCATION_KEYWORDS=tunisia,tunisie,tunis,monastir,sfax,sousse,gouvernorat
SCRAPER_FETCH_CONTACTS_FROM_WEBSITE=true
SCRAPER_SITE_CRAWL_MAX_PAGES=22
SCRAPER_SITE_CRAWL_TOTAL_SECONDS=55
SCRAPER_LINKEDIN_CONTACT_EMAIL_PAINT_MAX_MS=3500
SCRAPER_SITE_DEEP_SITEMAP=true
SCRAPER_SITE_DEEP_PROBE_EXTRA=true
# Mode rapide : après accueil/contact/mentions, pas de crawl BFS (évite les dépassements de délai)
SCRAPER_SITE_CRAWL_BFS_IN_FAST_MODE=false
# Scan About / Expérience / HTML (mailto) sur le profil en plus du panneau Coordonnées
SCRAPER_PROFILE_WIDE_CONTACT_SCAN=true
# Si e-mail / tél / site encore vides : ouvrir l’overlay coordonnées de la 1re entreprise (expérience)
SCRAPER_LINKEDIN_COMPANY_CONTACT_FALLBACK=true
# E-mails probables prenom.nom@domaine (activé par défaut — risque de bounce ; désactiver avec false)
SCRAPER_GUESS_CONTACT_EMAILS=true
SCRAPER_GUESS_EMAIL_REQUIRE_MX=true
# Logs détaillés (raisons / sources) vers le logger « scraper.linkedin_profile »
SCRAPER_CONTACT_TRACE_LOGS=true
# Attente max (ms) après ouverture Coordonnées pour laisser apparaître @ / mailto (0 = désactiver)
SCRAPER_LINKEDIN_CONTACT_EMAIL_PAINT_MAX_MS=6000

# Collecte web via Google (ou Bing / DuckDuckGo en secours)
SCRAPER_WEB_DISCOVERY_ENABLED=true
SCRAPER_WEB_SEARCH_PROVIDER=auto
SCRAPER_WEB_GOOGLE_USE_PLAYWRIGHT=true
SCRAPER_WEB_GOOGLE_API_KEY=
SCRAPER_WEB_GOOGLE_CX=
SCRAPER_WEB_GOOGLE_HL=fr
SCRAPER_WEB_GOOGLE_GL=
SCRAPER_WEB_OUTPUT_CSV=leads/scraper_web_google.csv
SCRAPER_WEB_MAX_RESULTS_PER_QUERY=15
SCRAPER_WEB_MAX_QUERIES_PER_RUN=4
SCRAPER_WEB_PAUSE_BETWEEN_REQUESTS_SECONDS=2.5
SCRAPER_WEB_HTTP_TIMEOUT_SECONDS=25
SCRAPER_WEB_LINKEDIN_INCLUDE_COMPANIES=false
SCRAPER_WEB_INSTAGRAM_PLAYWRIGHT_FALLBACK=true

# Navigateur PC (session déjà ouverte)
# storage = fichier sessions/*.json | cdp = Chrome/Edge ouvert avec --remote-debugging-port=9222
BROWSER_CONNECTION_MODE=storage
BROWSER_CDP_URL=http://127.0.0.1:9222
BROWSER_CHANNEL=
BROWSER_FROM=chrome
BROWSER_PROFILE=Default

# Connector orchestrator
CONNECTOR_SOURCE_CSV=leads/scraper_output.csv
CONNECTOR_QUEUE_PATH=bot/leads_queue.json
CONNECTOR_SQLITE_PATH=data/connector.db
CONNECTOR_PROCESSED_LOG=logs/connector_processed_leads.jsonl
CONNECTOR_FAILED_LOG=logs/connector_failed_leads.jsonl
CONNECTOR_EXPORT_MODE=both
CONNECTOR_SCHEDULE_HOURS=0
CONNECTOR_AUTO_INGEST=true
MONGODB_URI=
MONGODB_DB=outreach
MONGODB_COLLECTION=scraper_leads

# Platform
# ── Pipeline email post-enrichissement ───────────────────────────────────────
SCRAPER_EMAIL_PIPELINE_ENABLED=false
SCRAPER_EMAIL_PIPELINE_SCORE_THRESHOLD=3.0

# ── Cache incrémental ─────────────────────────────────────────────────────────
SCRAPER_PROFILE_CACHE_ENABLED=true
SCRAPER_PROFILE_CACHE_PATH=data/scraper_cache.db
SCRAPER_PROFILE_CACHE_TTL_DAYS=7
SCRAPER_PROFILE_CACHE_TTL_NO_EMAIL_DAYS=1

APP_DB_PATH=data/app.db
STORAGE_BACKEND=sqlite
OPT_OUT_CSV=compliance/opt_out.csv
LOGGING_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
API_KEY=
DASHBOARD_PASSWORD=

# Redis — file jobs scraper (Phase 2). Vide = exécution synchrone via API.
REDIS_URL=redis://localhost:6379/0
SCRAPER_QUEUE_SYNC_FALLBACK=true
SCRAPER_USE_REDIS_QUEUE=true
SCRAPER_QUEUE_POLL_SECONDS=2

# PostgreSQL (Phase 3 — optionnel)
# STORAGE_BACKEND=postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/outreach

# Sessions LinkedIn séparées (recommandé) :
#   sessions/linkedin-scrape.json  → collecte
#   sessions/linkedin-outreach.json → messages outreach
# Legacy sessions/linkedin.json reste supporté (repli).
# linkedin-publish → publication posts Content OS

# ── AI LinkedIn Content OS ────────────────────────────────────────────────────
CONTENT_AI_PROVIDER=
CONTENT_OPENAI_MODEL=
CONTENT_CLAUDE_API_KEY=
CONTENT_CLAUDE_MODEL=claude-3-5-sonnet-20241022
CONTENT_MAX_POSTS_PER_DAY=2
CONTENT_PUBLISH_SESSION_CHANNEL=linkedin-publish
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
BROWSER_POOL_MAX_SLOTS=2
STORAGE_BACKEND=sqlite
LEADS_CSV_EXPORT=true
DATABASE_URL=postgresql://aios:aios@localhost:5432/aios
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=
OAUTH_LINKEDIN_REDIRECT_URI=http://127.0.0.1:8000/api/v1/oauth/linkedin/callback
WEB_APP_URL=http://127.0.0.1:3000
SECRETS_ENCRYPTION_KEY=change-me-in-production-32chars
SENTRY_DSN=
OTEL_ENABLED=false
BROWSER_GRID_MODE=local
BROWSER_GRID_URL=http://127.0.0.1:8090
DEFAULT_REGION=eu-west
SUPPORTED_LOCALES=fr,en
OIDC_ISSUER=
OIDC_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aios-media
R2_PUBLIC_BASE_URL=

# Production hardening
APP_ENV=development
WORKER_JOB_TIMEOUT_SECONDS=3600
WORKER_HEARTBEAT_TTL_SECONDS=60
WORKER_PROCESSING_STALE_SECONDS=3600
QUEUE_JOB_TTL_SECONDS=604800
BROWSER_POOL_RECYCLE_PAGES=50
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
RETENTION_EVENTS_DAYS=90
RETENTION_SCRAPER_JOBS_DAYS=30
# Prod: redis://:STRONG_PASSWORD@redis.internal:6379/0
